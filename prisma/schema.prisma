// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Package {
  id        Int      @id @default(autoincrement())
  name      String
  length    Float
  width     Float
  height    Float
  weight           Float
  valueOfRepayment String?
  createdAt        DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Carrier {
  id            Int            @id @default(autoincrement())
  name          String
  trackingUrl   String
  isActive      Boolean        @default(true)
  dispatchments Dispatchment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Parcel {
  id             Int           @id @default(autoincrement())
  orderId        String
  orderName      String        @default("")
  fulfillmentId  String
  carrierId      Int?
  carrierName    String
  awbNumber      String
  length         Float
  width          Float
  height         Float
  weight           Float
  valueOfRepayment String?
  dispatchStatus   String        @default("pending")
  dispatchmentId Int?
  dispatchment   Dispatchment? @relation(fields: [dispatchmentId], references: [id])
  addons         ParcelAddon[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Dispatchment {
  id            Int      @id @default(autoincrement())
  carrierId     Int
  carrier       Carrier  @relation(fields: [carrierId], references: [id])
  transitStatus String   @default("pending")
  notes         String?
  parcels       Parcel[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StaffMember {
  id          Int      @id @default(autoincrement())
  name        String
  designation String?
  image       String?
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AddonProduct {
  id        Int           @id @default(autoincrement())
  name      String
  stock     Int           @default(0)
  isActive  Boolean       @default(true)
  parcels   ParcelAddon[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ParcelAddon {
  id        Int          @id @default(autoincrement())
  parcelId  Int
  parcel    Parcel       @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  addonId   Int
  addon     AddonProduct @relation(fields: [addonId], references: [id], onDelete: Cascade)
  quantity  Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([parcelId, addonId])
}

model CustomOrder {
  id                Int      @id @default(autoincrement())
  orderName         String   @unique
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  address1          String?
  address2          String?
  city              String?
  province          String?
  zip               String?
  country           String   @default("IN")
  phone             String?
  totalAmount       Float    @default(0)
  items             String?  // JSON text: [{variantId, productId, title, quantity, price}]
  paymentStatus     String   @default("UNPAID") // UNPAID, PARTIALLY PAID, FULLY PAID
  fulfillmentStatus String   @default("UNFULFILLED") // UNFULFILLED, FULFILLED
  partialPaymentAmount Float? @default(0)
  discountType      String?   // "fixed" or "percent"
  discountValue     Float?    @default(0)
  orderType         String    @default("Standard")
  partialPaymentLink   String?
  remainingPaymentLink String?
  fullPaymentLink      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TransactionHistory {
  id              Int      @id @default(autoincrement())
  orderName       String
  amountPaid      Float
  currency        String   @default("INR")
  paymentLinkId   String?
  paymentId       String?
  status          String   @default("SUCCESS") // SUCCESS, PENDING
  mode            String   @default("Razorpay") // Razorpay or Manual
  documentUrl     String?  // for manual uploads
  createdAt       DateTime @default(now())

  @@index([orderName])
}

