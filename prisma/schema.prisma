// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Package {
  id        Int      @id @default(autoincrement())
  name      String
  length    Float
  width     Float
  height    Float
  weight           Float
  valueOfRepayment String?
  createdAt        DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Carrier {
  id            Int            @id @default(autoincrement())
  name          String
  trackingUrl   String
  isActive      Boolean        @default(true)
  dispatchments Dispatchment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Parcel {
  id             Int           @id @default(autoincrement())
  orderId        String
  orderName      String        @default("")
  fulfillmentId  String
  carrierId      Int?
  carrierName    String
  awbNumber      String
  length         Float
  width          Float
  height         Float
  weight           Float
  valueOfRepayment String?
  dispatchStatus   String        @default("pending")
  dispatchmentId Int?
  dispatchment   Dispatchment? @relation(fields: [dispatchmentId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Dispatchment {
  id            Int      @id @default(autoincrement())
  carrierId     Int
  carrier       Carrier  @relation(fields: [carrierId], references: [id])
  transitStatus String   @default("pending")
  notes         String?
  parcels       Parcel[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StaffMember {
  id          Int      @id @default(autoincrement())
  name        String
  designation String?
  image       String?
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
